{
  "name": "@codehourra/llm-iwiki",
  "version": "0.1.2",
  "description": "面向 AI Agent 的本地知识库 CLI：采集 Claude Code / Cursor / Codex / CodeBuddy / Gemini 会话，按项目归一化，生成总结与经验并导出到 Obsidian。",
  "type": "module",
  "license": "MIT",
  "author": "CodeHourra",
  "homepage": "https://github.com/CodeHourra/llm-iwiki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeHourra/llm-iwiki.git"
  },
  "bugs": {
    "url": "https://github.com/CodeHourra/llm-iwiki/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "knowledge-base",
    "obsidian",
    "claude-code",
    "cursor",
    "codex",
    "bun"
  ],
  "bin": {
    "llm-iwiki": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --target bun --minify --outfile dist/index.js",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "~5.7",
    "yaml": "^2.7.0"
  }
}
