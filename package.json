{
  "name": "@codehourra/llm-iwiki",
  "version": "0.3.1",
  "description": "面向 AI Agent 的本地知识库 CLI：采集 Claude Code / Cursor / Codex / CodeBuddy / Gemini 会话，按项目归一化，生成总结与经验并导出到 Obsidian。",
  "type": "module",
  "license": "MIT",
  "author": "CodeHourra",
  "homepage": "https://github.com/CodeHourra/llm-iwiki#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeHourra/llm-iwiki.git"
  },
  "bugs": {
    "url": "https://github.com/CodeHourra/llm-iwiki/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "knowledge-base",
    "obsidian",
    "claude-code",
    "cursor",
    "codex",
    "node"
  ],
  "bin": {
    "llm-iwiki": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "docs/roadmap.md",
    "docs/roadmap.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --target node --minify --external better-sqlite3 --external bun:sqlite --outfile dist/index.js",
    "changeset": "changeset",
    "check:changeset": "bun run scripts/check-changeset-required.ts",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.11",
    "typescript": "~5.7",
    "yaml": "^2.7.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
